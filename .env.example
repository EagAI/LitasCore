# Kanalai (Discord snowflake ID)
WELCOME_CHANNEL_ID=
LOG_CHANNEL_ID=
IDEAS_CHANNEL_ID=
BOOST_CHANNEL_ID=
LEVEL_UP_CHANNEL_ID=
YOUTUBE_ANNOUNCE_CHANNEL_ID=
VOICE_CATEGORY_ID=
TICKETS_CATEGORY_ID=

# Antiscam / mod veiksmai — gali sutapti su LOG arba būti atskiras
ADMIN_ACTIONS_CHANNEL_ID=

# Pasekinių skelbimas (lygio pakilimai); jei tuščia, naudojamas LEVEL_UP_CHANNEL_ID
PASEKIMU_CHANNEL_ID=

# Rolės
WELCOME_ROLE_ID=
STAFF_ROLE_IDS=
MOD_ROLE_IDS=
# Blacklist rolė: išėjikų DB žyma, giveaway blokas (tuščia = rolės priskyrimo / blokų nėra)
BLACKLIST_ROLE_ID=

# Lygio milestone rolės — tik Discord role ID (pagal poreikį įrašyk lygius)
# Formatas: LEVEL_<lygis>_ROLE_ID (pvz. LEVEL_5_ROLE_ID). Tuščias = praleisti tą milestone.
LEVEL_5_ROLE_ID=
LEVEL_10_ROLE_ID=
LEVEL_15_ROLE_ID=
LEVEL_20_ROLE_ID=
LEVEL_25_ROLE_ID=
LEVEL_30_ROLE_ID=
LEVEL_35_ROLE_ID=
LEVEL_40_ROLE_ID=

# Ženkleliai /admin — tik custom emoji snowflake ID (vardai serveryje: streamer, vip, …)
STREAMER_BADGE_ID=
VIP_BADGE_ID=
SUPPORTERIS_BADGE_ID=
PADEKA_BADGE_ID=
ADMINISTRACIJA_BADGE_ID=

# Custom server emoji (Discord snowflake ID). Tuščia = Unicode numatytieji.
# Pavadinimai serveryje: levelup, dovanos, dalyviai, clock, winner, lock
EMOJI_LEVELUP=
EMOJI_GIVEAWAY_GIFT=
EMOJI_GIVEAWAY_PARTICIPANTS=
EMOJI_GIVEAWAY_CLOCK=
EMOJI_GIVEAWAY_WINNER=
EMOJI_GIVEAWAY_LOCK=
# Neprivaloma: „Dalyvauti“ mygtukas (jei tuščia – naudojamas PARTICIPANTS)
EMOJI_GIVEAWAY_ENTER=

# YouTube (vienas kanalo UC ID)
YOUTUBE_CHANNEL_ID=

# TikTok profile URL (YouTube skelbimuose)
TIKTOK_URL=

# Anti-ping thresholds
ANTI_PING_WINDOW_MS=600000
ANTI_PING_WARN_THRESHOLD=3
ANTI_PING_TIMEOUT_THRESHOLD=5
ANTI_PING_TIMEOUT_DURATION_MS=1800000

# XP
# Lygio milestone roles: false = tik viena aukščiausia; true = stack (visos pasiektos)
LEVEL_ROLES_STACK=false
XP_COOLDOWN_MS=5000
XP_PER_MESSAGE=15

# Sukčiavimo paveikslų skenavimas (OCR, tesseract.js)
SCAM_SCAN_ENABLED=true
SCAM_SCORE_THRESHOLD=4
SCAM_TIMEOUT_MS=86400000
SCAM_SCAN_CHANNEL_IDS=
