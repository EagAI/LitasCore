# Bot
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

# Antiscam (ban/timeout mygtukai) ir panašūs mod veiksmai — atskiras kanalas nuo bendro „log“
ADMIN_ACTIONS_CHANNEL_ID=

# YouTube (comma-separated channel IDs)
YOUTUBE_CHANNEL_IDS=

# Anti-ping thresholds
ANTI_PING_WINDOW_MS=600000
ANTI_PING_WARN_THRESHOLD=3
ANTI_PING_TIMEOUT_THRESHOLD=5
ANTI_PING_TIMEOUT_DURATION_MS=1800000

# XP
# Lygio pakilimų skelbimas pasekinių kanale (PASEKIMU); jei tuščia, naudojamas levelUpChannelId iš channelIds
PASEKIMU_CHANNEL_ID=
XP_COOLDOWN_MS=5000
XP_PER_MESSAGE=15
VOICE_XP_PER_MINUTE=8

# Sukčiavimo paveikslų skenavimas (OCR, tesseract.js)
# Svarbu: Developer portale (Bot) įjunkite „Message Content Intent“.
# Botui serveryje: „Moderate Members“ (timeout). Log kanalui: siųsti žinutes, priedus, embed.
# Skenavimo kanaluose: skaityti pranešimus, žiūrėti priedus, trinti žinutes („Manage Messages“).
SCAM_SCAN_ENABLED=true
SCAM_SCORE_THRESHOLD=4
# Timeout trukmė ms (numatyta 1 d. = 86400000)
SCAM_TIMEOUT_MS=86400000
# Kableliais atskirti kanalų ID; tuščia = visi kanalai
SCAM_SCAN_CHANNEL_IDS=
